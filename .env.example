# API base URL — must include /api/v1 (same as promang-frontend)
REACT_APP_BACKEND_URL=http://localhost:4000/api/v1

# Doorkeeper OAuth app (copy from promang-frontend .env for local dev)
REACT_APP_CLIENT_ID=your_client_id
REACT_APP_CLIENT_SECRET=your_client_secret

# Use 3001 when promang-frontend already runs on CRA default 3000 (must match promang-api CORS_ORIGINS)
PORT=3001
